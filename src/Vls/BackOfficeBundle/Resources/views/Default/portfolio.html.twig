{% extends 'VlsBackOfficeBundle::layout.html.twig' %}

{% block title %}
{{ parent() }} - Portfolio
{% endblock %}

{% block page_title %}
<h1>Portfolio</h1>
{% endblock %}

{% block content %}
<div class="row">
    <div class="col-md-8">
        <div class="panel panel-primary">
            <div class="panel-heading">
                <h3 class="panel-title"><i class="fa fa-th"></i> Ajout de portfolio</h3>
            </div>
            <div class="panel-body">
                {{ form(portfolioForm) }}
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="panel panel-primary">
            <div class="panel-heading">
                <h3 class="panel-title"><i class="fa fa-th"></i> Liste des portfolios</h3>
            </div>
            <div class="panel-body">
                <ul class="list-unstyled">
                    {% for portfolio in portfolios %}
                    <li>
                        {{ portfolio.title }}
                    </li>
                    {% endfor %}
                </ul>
            </div>
        </div>
    </div>
</div>
{% endblock %}
